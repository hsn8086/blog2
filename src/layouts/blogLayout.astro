---
import "../styles/global.css";
import { Separator } from "@/components/ui/separator";
import ProfileSidebar from "@/components/ProfileSidebar.vue";
import MobileHeader from "@/components/MobileHeader.astro";
import { ClientRouter } from "astro:transitions";
import {
    authorUrl,
    avatarUrl,
    locale,
    siteDescription,
    siteName,
    userName,
} from "@/blog.config";

interface Props {
    title?: string;
    description?: string;
    image?: string;
    schemaType?: "Blog" | "BlogPosting" | "CollectionPage" | "WebPage";
    publishedTime?: Date;
    modifiedTime?: Date;
    tags?: string[];
    comments?: boolean;
    katex?: boolean;
}

const {
    title = siteName,
    description = siteDescription,
    image = avatarUrl,
    schemaType = "WebPage",
    publishedTime,
    modifiedTime = publishedTime,
    tags = [],
    comments = false,
    katex = false,
} = Astro.props;

const baseUrl = Astro.site ?? new URL(Astro.url.origin);
const siteUrl = new URL("/", baseUrl).toString();
const canonicalUrl = new URL(Astro.url.pathname, baseUrl).toString();
const imageUrl = new URL(image, baseUrl).toString();
const avatarImageUrl = new URL(avatarUrl, baseUrl).toString();
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const imageAlt = title === siteName ? siteName : `${title} - ${siteName}`;
const authorId = `${siteUrl}#author`;
const websiteId = `${siteUrl}#website`;
const pageId = `${canonicalUrl}#webpage`;

const pageSchema =
    schemaType === "BlogPosting"
        ? {
              "@type": "BlogPosting",
              "@id": `${canonicalUrl}#article`,
              headline: title,
              description,
              image: [imageUrl],
              datePublished: publishedTime?.toISOString(),
              dateModified: modifiedTime?.toISOString(),
              author: { "@id": authorId },
              publisher: { "@id": authorId },
              mainEntityOfPage: canonicalUrl,
              isPartOf: { "@id": websiteId },
              articleSection: tags[0],
              keywords: tags,
              isAccessibleForFree: true,
              inLanguage: locale,
          }
        : {
              "@type": schemaType,
              "@id": pageId,
              url: canonicalUrl,
              name: title,
              description,
              author: { "@id": authorId },
              isPartOf: { "@id": websiteId },
              inLanguage: locale,
          };

const structuredData = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Person",
            "@id": authorId,
            name: userName,
            url: authorUrl,
            image: avatarImageUrl,
            sameAs: ["https://github.com/hsn8086"],
        },
        {
            "@type": "WebSite",
            "@id": websiteId,
            url: siteUrl,
            name: siteName,
            description: siteDescription,
            publisher: { "@id": authorId },
            inLanguage: locale,
        },
        pageSchema,
    ],
}).replace(/</g, "\\u003c");
---

<html lang={locale}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="author" content={userName} />
        <meta name="description" content={description} />
        <meta
            name="robots"
            content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
        />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        {
            katex && (
                <link
                    href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css"
                    rel="stylesheet"
                />
            )
        }
        <meta property="og:type" content={schemaType === "BlogPosting" ? "article" : "website"} />
        <meta property="og:locale" content="zh_CN" />
        <meta property="og:site_name" content={siteName} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={imageUrl} />
        <meta property="og:image:alt" content={imageAlt} />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={imageUrl} />
        {
            publishedTime && (
                <meta property="article:published_time" content={publishedTime.toISOString()} />
            )
        }
        {
            modifiedTime && (
                <meta property="article:modified_time" content={modifiedTime.toISOString()} />
            )
        }
        {tags.map((tag) => <meta property="article:tag" content={tag} />)}
        <title>{pageTitle}</title>
        <script is:inline type="application/ld+json" set:html={structuredData}></script>
        <ClientRouter />
    </head>
    <body>
        <div
            class="flex flex-col-reverse max-w-screen md:flex-row md:overflow-hidden md:h-screen"
        >
            <!-- Left: Profile Sidebar (Vue Component) -->
            <ProfileSidebar
                class="shrink-0 w-full md:w-auto md:overflow-y-auto md:max-w-72"
            />

            <!-- Separators -->
            <Separator
                orientation="vertical"
                class="hidden md:block shrink-0"
            />
            <Separator
                orientation="horizontal"
                class="w-full md:hidden shrink-0"
            />

            <!-- Right: Blog Content -->
            <main class="px-8 py-8 grow overflow-x-hidden md:overflow-y-auto">
                <!-- Mobile Header: Fixed at top -->
                <div
                    class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md md:hidden px-8 py-4"
                >
                    <MobileHeader />
                </div>

                <!-- 占位符，防止内容被 fixed 元素遮挡 -->
                <div class="h-16 md:hidden"></div>

                <slot />
                {
                    comments && (
                        <div class="mt-16 max-w-2xl mx-auto">
                            <script
                                is:inline
                                data-astro-rerun
                                src="https://giscus.app/client.js"
                                data-repo="hsn8086/blog-comment"
                                data-repo-id="R_kgDOMrzYig"
                                data-category="General"
                                data-category-id="DIC_kwDOMrzYis4CiJyc"
                                data-mapping="pathname"
                                data-strict="0"
                                data-reactions-enabled="1"
                                data-emit-metadata="0"
                                data-input-position="bottom"
                                data-theme="light"
                                data-lang="zh-CN"
                                crossorigin="anonymous"
                                async
                            />
                        </div>
                    )
                }
            </main>
        </div>
    </body>
</html>
