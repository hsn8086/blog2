//
interface FeedProps {
    data: {
        title: string;
        date: Date;
    };
    id: string;
}
const { posts } = Astro.props as { posts: FeedProps[] };
---

<div class="space-y-6">
    <ul class="space-y-1">
        {
            posts.map((post) => (
                <li class="px-4 py-4 rounded-lg w-full hover:bg-gray-100 dark:hover:bg-gray-800">
                    <article>
                        <h2 class="text-xl font-semibold">
                            <a
                                href={`/${post.data.date.getUTCFullYear()}/${(post.data.date.getUTCMonth() + 1).toString().padStart(2, "0")}/${post.data.date.getUTCDate().toString().padStart(2, "0")}/${post.id}`}
                                class="block"
                            >
                                {post.data.title}
                            </a>
                        </h2>
                        <time
                            datetime={post.data.date.toISOString()}
                            class="block text-sm text-muted-foreground mt-1"
                        >
                            {post.data.date.toLocaleDateString("zh-CN", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                                timeZone: "UTC",
                            })}
                        </time>
                    </article>
                </li>
            ))
        }
    </ul>
</div>
